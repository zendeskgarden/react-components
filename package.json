{
  "name": "@zendeskgarden/react-components",
  "version": "9.15.0",
  "description": "Garden design system React components",
  "keywords": [
    "components",
    "garden",
    "react",
    "zendesk"
  ],
  "homepage": "https://garden.zendesk.com/",
  "bugs": {
    "url": "https://github.com/zendeskgarden/react-components/issues"
  },
  "license": "Apache-2.0",
  "author": "Zendesk Garden <garden@zendesk.com>",
  "repository": "github:zendeskgarden/react-components",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b && tsdown --config config/tsdown.config.ts",
    "build:demo": "storybook build --config-dir config/storybook --output-dir .cache/demo",
    "format": "oxfmt --config config/oxfmtrc.json",
    "lint:ci": "pnpm format --check && pnpm lint && pnpm lint:css && pnpm lint:js",
    "lint:css": "stylelint --config config/stylelint.config.js ./src/views/**/*.ts",
    "lint:js": "eslint --config config/eslint.config.js --max-warnings 0 .",
    "lint": "oxlint --config config/oxlintrc.json",
    "start": "storybook dev --config-dir config/storybook --no-version-updates -p 6006",
    "tag": "scripts/tag.js",
    "test": "vitest --config config/vitest.config.ts"
  },
  "dependencies": {
    "@zendeskgarden/container-accordion": "^3.0.15",
    "@zendeskgarden/container-utilities": "^2.0.5",
    "@zendeskgarden/react-theming": "^9.15.0",
    "prop-types": "^15.8.1"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "10.3.0",
    "@storybook/addon-designs": "11.1.2",
    "@storybook/addon-docs": "10.3.0",
    "@storybook/react-vite": "10.3.0",
    "@svgr/plugin-jsx": "8.1.0",
    "@svgr/plugin-svgo": "8.1.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.5.0",
    "@types/prop-types": "15.7.15",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vanilla-extract/css": "1.19.1",
    "@vanilla-extract/rollup-plugin": "1.5.3",
    "@vanilla-extract/vite-plugin": "5.2.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "@zendeskgarden/eslint-config": "47.1.0",
    "@zendeskgarden/react-buttons": "9.15.0",
    "@zendeskgarden/react-tooltips": "9.15.0",
    "@zendeskgarden/scripts": "2.5.3",
    "@zendeskgarden/stylelint-config": "23.0.0",
    "@zendeskgarden/svg-icons": "8.2.0",
    "commander": "14.0.3",
    "envalid": "8.1.1",
    "eslint": "9.39.4",
    "execa": "9.6.1",
    "inquirer": "13.3.2",
    "jsdom": "28.1.0",
    "lerna": "9.0.7",
    "ora": "9.3.0",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "postcss-styled-syntax": "0.7.1",
    "publint": "0.3.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "storybook": "10.3.0",
    "styled-components": "6.3.11",
    "stylelint": "17.4.0",
    "temp": "0.9.4",
    "tsdown": "0.21.4",
    "typescript": "5.9.3",
    "vite-plugin-svgr": "4.5.0",
    "vitest": "4.1.0"
  },
  "peerDependencies": {
    "@vanilla-extract/css": "^1.18.0",
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "styled-components": "^6.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
