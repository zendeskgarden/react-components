{
  "extends": "@tsconfig/strictest/tsconfig.json",
  "compilerOptions": {
    "exactOptionalPropertyTypes": false,
    "jsx": "react-jsx",
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noPropertyAccessFromIndexSignature": false,
    "skipLibCheck": true,
    "target": "esnext",
    "tsBuildInfoFile": "../node_modules/.tmp/tsconfig.tsbuildinfo"
  },
  "include": [".", "../demo", "../src"]
}
